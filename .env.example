# Risk Dashboard Namecheap Node.js API environment
# Copy this file to .env on your Namecheap Node.js application root.
# Do not commit the real .env file.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=cpaneluser_risk_user
MYSQL_PASSWORD=DATABASE_PASSWORD
MYSQL_DATABASE=cpaneluser_risk_dashboard
RISK_SKIP_CREATE_DATABASE=1

RISK_SESSION_SECRET=LONG_RANDOM_SECRET_CHANGE_THIS
RISK_SESSION_TTL_HOURS=8
RISK_MAX_FAILED_LOGINS=5
RISK_LOCKOUT_MINUTES=15
RISK_COOKIE_NAME=risk_session
# Use this on production subdomain if cookies need to work between risks-dashboard.com and api.risks-dashboard.com
# RISK_COOKIE_DOMAIN=.risks-dashboard.com
RISK_COOKIE_SECURE=true

API_PORT=4000
NODE_ENV=production

# Comma-separated list. Keep production domains here.
RISK_CORS_ORIGINS=https://risks-dashboard.com,https://www.risks-dashboard.com,http://127.0.0.1:5173,http://localhost:5173
